{
  "name": "amd_act_ii_pipeline",
  "version": 1,
  "schemaVersion": 2,
  "ownerEmail": "hi@forenly.ai",
  "description": "AMD ACT II — GrootNet hackathon delivery (build Jul 6-11). Roles: Platform(Naqi) -> ML(Mohnaa) -> Integration(Dundu) -> Lead(Bahadir, +demo+lablab) + Associate Lead(swati). Each handoff @mentions the owner in Discord. Track by correlationId=amd-act-ii.",
  "inputParameters": ["team", "discord_webhook"],
  "tasks": [
    {"name": "notify_setup", "taskReferenceName": "notify_setup", "type": "HTTP",
     "inputParameters": {"http_request": {"uri": "${workflow.input.discord_webhook}", "method": "POST", "contentType": "application/json",
       "body": {"content": ":gear: **Platform** <@446476397813170186> — GrootNet `${workflow.workflowId}`: **pre-hack setup** (lablab.ai kayit, AMD Developer Cloud, krediler, MI300X/ROCm env)."}}}},
    {"name": "prehack_setup_gate", "taskReferenceName": "prehack_setup_gate", "type": "HUMAN",
     "inputParameters": {"role": "platform", "assignee": "naqi", "checklist": "lablab.ai team registered; AMD Developer Cloud active; credits; MI300X/ROCm env"}},
    {"name": "setup_router", "taskReferenceName": "setup_router", "type": "SWITCH",
     "evaluatorType": "value-param", "expression": "decision",
     "inputParameters": {"decision": "${prehack_setup_gate.output.decision}"},
     "decisionCases": {"reject": [{"name": "setup_block", "taskReferenceName": "setup_block", "type": "TERMINATE",
        "inputParameters": {"terminationStatus": "FAILED", "terminationReason": "setup blocked -> Platform"}}]}, "defaultCase": []},

    {"name": "notify_build1", "taskReferenceName": "notify_build1", "type": "HTTP",
     "inputParameters": {"http_request": {"uri": "${workflow.input.discord_webhook}", "method": "POST", "contentType": "application/json",
       "body": {"content": ":one: **ML** <@1504518245045108830> — GrootNet `${workflow.workflowId}`: **Build Sprint 1 — agent core** basladi."}}}},
    {"name": "build_agent_core", "taskReferenceName": "build_agent_core", "type": "SIMPLE",
     "inputParameters": {"role": "ml", "artifact": "multi-agent robotic brain core", "gpu": "MI300X/ROCm"}},
    {"name": "agent_core_gate", "taskReferenceName": "agent_core_gate", "type": "HUMAN",
     "inputParameters": {"role": "lead", "accountable": "lead", "step": "agent-core sign-off"}},

    {"name": "notify_build2", "taskReferenceName": "notify_build2", "type": "HTTP",
     "inputParameters": {"http_request": {"uri": "${workflow.input.discord_webhook}", "method": "POST", "contentType": "application/json",
       "body": {"content": ":two: **ML+Integration** <@1504518245045108830> <@1509893434868109464> — GrootNet `${workflow.workflowId}`: **Build Sprint 2 — ROCm serving + decentralized mesh** (paralel)."}}}},
    {"name": "build_sprint2", "taskReferenceName": "build_sprint2", "type": "FORK_JOIN",
     "forkTasks": [
       [{"name": "rocm_serving", "taskReferenceName": "rocm_serving", "type": "SIMPLE",
         "inputParameters": {"role": "ml", "task": "serve agents across MI300X fleet via ROCm"}}],
       [{"name": "integration_mesh", "taskReferenceName": "integration_mesh", "type": "SIMPLE",
         "inputParameters": {"role": "integration", "task": "wire decentralized GrootNet mesh end-to-end"}}]
     ]},
    {"name": "build_sprint2_join", "taskReferenceName": "build_sprint2_join", "type": "JOIN",
     "joinOn": ["rocm_serving", "integration_mesh"]},
    {"name": "integration_gate", "taskReferenceName": "integration_gate", "type": "HUMAN",
     "inputParameters": {"role": "integration", "assignee": "dundu", "step": "integration sign-off (e2e runs)"}},

    {"name": "notify_demo", "taskReferenceName": "notify_demo", "type": "HTTP",
     "inputParameters": {"http_request": {"uri": "${workflow.input.discord_webhook}", "method": "POST", "contentType": "application/json",
       "body": {"content": ":clapper: **Lead + Associate Lead** <@1486073506335817748> <@876814494762946590> — GrootNet `${workflow.workflowId}`: **demo video + lablab.ai submission** (Lead lablab profilini yonetir)."}}}},
    {"name": "demo_prep", "taskReferenceName": "demo_prep", "type": "SIMPLE",
     "inputParameters": {"role": "lead+associate-lead", "artifact": "3-min demo video + lablab.ai submission draft"}},
    {"name": "final_gate", "taskReferenceName": "final_gate", "type": "HUMAN",
     "inputParameters": {"role": "lead", "accountable": "lead", "step": "final sign-off before submit"}},
    {"name": "final_router", "taskReferenceName": "final_router", "type": "SWITCH",
     "evaluatorType": "value-param", "expression": "decision",
     "inputParameters": {"decision": "${final_gate.output.decision}"},
     "decisionCases": {"reject": [{"name": "final_reject", "taskReferenceName": "final_reject", "type": "TERMINATE",
        "inputParameters": {"terminationStatus": "FAILED", "terminationReason": "final review rejected -> demo prep"}}]}, "defaultCase": []},

    {"name": "submit", "taskReferenceName": "submit", "type": "SIMPLE",
     "inputParameters": {"role": "lead", "target": "lablab.ai submission"}},
    {"name": "notify_done", "taskReferenceName": "notify_done", "type": "HTTP",
     "inputParameters": {"http_request": {"uri": "${workflow.input.discord_webhook}", "method": "POST", "contentType": "application/json",
       "body": {"content": ":checkered_flag: **SUBMITTED** — GrootNet `${workflow.workflowId}` teslim edildi. GG team! :trophy:"}}}}
  ]
}
